              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "assets",
                "page"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                },
                {
                  "key": "sortBy",
                  "value": "id"
                },
                {
                  "key": "sortDirection",
                  "value": "asc"
                }
              ]
            }
          }
        },
        {
          "name": "List Assets (Filtered by Class)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/assets/page?assetClass=COMPUTER_EQUIPMENT",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "assets",
                "page"
              ],
              "query": [
                {
                  "key": "assetClass",
                  "value": "COMPUTER_EQUIPMENT"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Asset",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/assets/{{assetId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "assets",
                "{{assetId}}"
              ]
            }
          }
        }
      ]
    },
