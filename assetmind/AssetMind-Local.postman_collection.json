{
  "info": {
    "name": "AssetMind Local API",
    "_postman_id": "8f25f2d0-03f6-4d5e-89af-6f5d9f845a68",
    "description": "Local API collection for AssetMind. Run Auth → Register then Login first to populate the token variable automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080" },
    { "key": "token",        "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "assetId",      "value": "laptop-001" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1 - Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"SecurePassword123\",\n  \"email\": \"john@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","register"]
            }
          }
        },
        {
          "name": "2 - Login (auto-saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "if (body.accessToken)  { pm.collectionVariables.set('token', body.accessToken); pm.environment.set('token', body.accessToken); }",
                  "if (body.refreshToken) { pm.collectionVariables.set('refreshToken', body.refreshToken); pm.environment.set('refreshToken', body.refreshToken); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"password\": \"SecurePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","login"]
            }
          }
        },
        {
          "name": "3 - Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "if (body.accessToken) { pm.collectionVariables.set('token', body.accessToken); pm.environment.set('token', body.accessToken); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","refresh"]
            }
          }
        }
      ]
    },
